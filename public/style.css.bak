:root {
  /* 基础色板 */
  --bg-0: #070b14;
  --bg-1: #0c111d;
  --bg-2: #111826;
  --felt-hi: #1ea15f;
  --felt: #148a4f;
  --felt-lo: #0a5233;
  --felt-edge: #073a24;
  --rail-hi: #4a3220;
  --rail-lo: #241408;

  --gold: #f4c94b;
  --gold-hi: #ffe08a;
  --gold-lo: #c9973a;

  --text: #eaf0f7;
  --muted: #93a1b3;
  --line: rgba(255,255,255,.08);
  --line-strong: rgba(255,255,255,.14);

  --red: #ef4d54;
  --red-hi: #ff6b70;
  --blue: #4a9bff;
  --teal: #2fd6a6;
  --green: #35c46a;

  /* 玻璃面板 */
  --glass: rgba(18,24,36,.72);
  --glass-2: rgba(24,31,45,.85);
  --shadow-lg: 0 24px 70px rgba(0,0,0,.55);
  --shadow-md: 0 10px 30px rgba(0,0,0,.4);
}

* { box-sizing: border-box; }
html, body { margin: 0; height: 100%; }
body {
  font-family: "Inter", -apple-system, "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
  background:
    radial-gradient(1200px 700px at 15% -10%, #16233d 0%, transparent 55%),
    radial-gradient(1000px 600px at 100% 0%, #1a1330 0%, transparent 50%),
    linear-gradient(160deg, var(--bg-1), var(--bg-0));
  color: var(--text);
  -webkit-font-smoothing: antialiased;
  letter-spacing: .2px;
}

.screen { min-height: 100vh; }
.hidden { display: none !important; }

::-webkit-scrollbar { width: 9px; height: 9px; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 8px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.2); }
::-webkit-scrollbar-track { background: transparent; }

/* ===================== 登录 / 大厅 ===================== */
#auth, #lobby {
  display: flex; align-items: center; justify-content: center; padding: 24px;
}
.lobby-card {
  position: relative;
  width: 380px; max-width: 92vw;
  background: linear-gradient(180deg, rgba(28,36,52,.9), rgba(15,20,31,.92));
  border: 1px solid var(--line-strong);
  border-radius: 20px;
  padding: 30px 26px;
  box-shadow: var(--shadow-lg), inset 0 1px 0 rgba(255,255,255,.06);
  backdrop-filter: blur(14px);
  animation: cardIn .5s cubic-bezier(.2,.8,.25,1) both;
}
.lobby-card::before {
  content: ""; position: absolute; inset: -1px; border-radius: 20px; padding: 1px;
  background: linear-gradient(135deg, rgba(244,201,75,.5), transparent 40%, transparent 60%, rgba(74,155,255,.35));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;
}
@keyframes cardIn { from { opacity: 0; transform: translateY(14px) scale(.98); } to { opacity: 1; transform: none; } }

.lobby-card h1 {
  margin: 0 0 6px; font-size: 27px; font-weight: 800; letter-spacing: .5px;
  background: linear-gradient(180deg, #fff, #cfd8e4);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.lobby-card .sub {
  font-size: 13px; font-weight: 700; letter-spacing: 1px;
  background: linear-gradient(90deg, var(--gold-hi), var(--gold-lo));
  -webkit-background-clip: text; background-clip: text; color: transparent;
  -webkit-text-fill-color: transparent;
}
.who {
  background: linear-gradient(90deg, rgba(244,201,75,.14), rgba(244,201,75,.04));
  border: 1px solid rgba(244,201,75,.28); border-radius: 10px;
  padding: 9px 13px; font-size: 13px; color: var(--gold-hi); margin-bottom: 4px; font-weight: 600;
}
.tip { color: var(--muted); font-size: 13px; line-height: 1.6; margin: 0 0 18px; }
label { display: block; font-size: 12px; color: var(--muted); margin: 14px 0 7px; font-weight: 600; letter-spacing: .3px; }

input, select {
  width: 100%; padding: 12px 13px; border-radius: 11px;
  border: 1px solid var(--line-strong); background: rgba(7,11,20,.7); color: var(--text);
  font-size: 15px; outline: none; transition: border-color .15s, box-shadow .15s, background .15s;
}
input::placeholder { color: #5a6675; }
input:focus, select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(244,201,75,.16); background: rgba(7,11,20,.9); }

button {
  width: 100%; margin-top: 14px; padding: 12px 14px;
  border: 1px solid var(--line-strong); border-radius: 11px; cursor: pointer;
  background: linear-gradient(180deg, rgba(48,58,74,.9), rgba(33,41,54,.9));
  color: var(--text); font-size: 15px; font-weight: 700; letter-spacing: .3px;
  transition: transform .12s ease, filter .15s, box-shadow .15s, background .15s;
}
button:hover { transform: translateY(-1px); filter: brightness(1.1); box-shadow: 0 6px 18px rgba(0,0,0,.35); }
button:active { transform: translateY(0); }
button:disabled { opacity: .38; cursor: not-allowed; transform: none; box-shadow: none; filter: none; }

button.primary {
  background: linear-gradient(180deg, var(--gold-hi), var(--gold-lo));
  color: #3a2a00; border-color: rgba(255,224,138,.6);
  box-shadow: 0 6px 20px rgba(244,201,75,.28);
}
button.primary:hover { box-shadow: 0 10px 28px rgba(244,201,75,.42); }
button.danger {
  background: linear-gradient(180deg, var(--red-hi), #c9363c); color: #fff;
  border-color: rgba(255,107,112,.5); box-shadow: 0 6px 18px rgba(239,77,84,.3);
}

.divider { text-align: center; color: var(--muted); margin: 20px 0 4px; position: relative; font-size: 13px; }
.divider::before { content: ""; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: var(--line); }
.divider span { position: relative; background: var(--bg-2); padding: 0 12px; border-radius: 8px; }
.msg { color: var(--red-hi); font-size: 13px; min-height: 18px; margin-top: 12px; text-align: center; }

/* 大厅：人机选项 */
.bot-opts {
  background: linear-gradient(180deg, rgba(7,11,20,.6), rgba(7,11,20,.3));
  border: 1px solid var(--line); border-radius: 14px; padding: 15px 16px; margin: 8px 0 4px;
}
.bot-title { font-weight: 800; color: var(--gold-hi); margin-bottom: 4px; font-size: 14px; }
.bot-opts .tip { margin: 0 0 8px; }
.bot-opts .row { display: flex; align-items: center; gap: 10px; margin-top: 11px; }
.bot-opts .row label { margin: 0; flex: 0 0 92px; }
.bot-opts .row select { flex: 1; width: auto; margin: 0; }
.bot-opts .row.check label { flex: 1; display: flex; align-items: center; gap: 8px; color: var(--text); font-size: 13px; }
.bot-opts input[type=checkbox] { width: 16px; height: 16px; accent-color: var(--gold); }

/* ===================== 游戏布局 ===================== */
#game {
  display: grid;
  grid-template-columns: 1fr 340px;
  grid-template-rows: auto 1fr auto;
  grid-template-areas: "top top" "table side" "action side";
  height: 100vh;
}
.topbar {
  grid-area: top; display: flex; align-items: center; gap: 16px;
  padding: 12px 20px;
  background: linear-gradient(180deg, rgba(20,27,40,.92), rgba(13,18,28,.86));
  border-bottom: 1px solid var(--line); backdrop-filter: blur(10px);
}
.room-box { font-size: 14px; color: var(--muted); display: flex; align-items: center; gap: 10px; }
.room-box b {
  color: #3a2a00; letter-spacing: 3px; font-size: 17px; font-weight: 800;
  background: linear-gradient(180deg, var(--gold-hi), var(--gold-lo));
  padding: 3px 12px; border-radius: 9px; box-shadow: 0 3px 12px rgba(244,201,75,.3);
}
.status { flex: 1; color: var(--muted); font-size: 14px; font-weight: 600; }
.mini {
  width: auto; margin: 0; padding: 7px 13px; font-size: 13px; border-radius: 9px;
  background: linear-gradient(180deg, rgba(48,58,74,.8), rgba(33,41,54,.8));
}
.mini.ghost { background: transparent; border: 1px solid var(--line-strong); color: var(--muted); }
.mini.ghost:hover { color: var(--text); border-color: var(--line-strong); }

/* ===================== 牌桌 ===================== */
.table-wrap { grid-area: table; display: flex; align-items: center; justify-content: center; padding: 12px; overflow: auto; }
.table {
  position: relative; width: min(820px, 92%); max-height: 48vh; aspect-ratio: 16/9;
  border-radius: 50% / 44%;
  /* 外圈皮革护栏 */
  background:
    linear-gradient(145deg, var(--rail-hi), var(--rail-lo));
  padding: 20px;
  box-shadow:
    0 30px 70px rgba(0,0,0,.6),
    inset 0 2px 3px rgba(255,255,255,.14),
    inset 0 -4px 10px rgba(0,0,0,.5);
}
.table::before {
  /* 绒面 */
  content: ""; position: absolute; inset: 20px; border-radius: 50% / 44%;
  background:
    radial-gradient(ellipse 62% 70% at 50% 42%, var(--felt-hi) 0%, var(--felt) 42%, var(--felt-lo) 78%, var(--felt-edge) 100%);
  box-shadow:
    inset 0 0 60px rgba(0,0,0,.5),
    inset 0 0 0 2px rgba(255,255,255,.06),
    inset 0 6px 20px rgba(255,255,255,.05);
}
.table::after {
  /* 中央装饰环 */
  content: ""; position: absolute; inset: 20px; border-radius: 50% / 44%;
  background:
    radial-gradient(ellipse 40% 46% at 50% 42%, transparent 60%, rgba(244,201,75,.06) 61%, transparent 63%);
  pointer-events: none;
}

.pot-center {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -62%);
  text-align: center; width: 72%; z-index: 2;
}
.pot {
  display: inline-flex; align-items: center; gap: 7px;
  color: var(--gold-hi); font-size: 13px; font-weight: 600; letter-spacing: .5px;
  background: rgba(0,0,0,.34); border: 1px solid rgba(244,201,75,.28);
  padding: 5px 15px; border-radius: 999px; backdrop-filter: blur(4px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 4px 14px rgba(0,0,0,.35);
}
.pot b { font-size: 19px; color: #fff; font-weight: 800; }
.board { display: flex; gap: 9px; justify-content: center; margin-top: 14px; min-height: 96px; }
/* 公共牌放大 */
.board .card { width: 60px; height: 84px; border-radius: 9px; }
.board .card .c-suit { font-size: 27px; }
.board .card .c-idx { font-size: 13px; top: 5px; left: 6px; }
.board .card .c-idx.br { bottom: 5px; right: 6px; }
.stage-label {
  color: #d6f2e2; font-size: 12px; margin-top: 10px; min-height: 16px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; text-shadow: 0 1px 4px rgba(0,0,0,.4);
}

/* ===================== 座位 ===================== */
.seats { position: absolute; inset: 0; z-index: 3; }
.seat {
  position: absolute; width: 152px; transform: translate(-50%, -50%);
  background: linear-gradient(180deg, rgba(16,22,33,.94), rgba(10,14,22,.94));
  border: 1px solid var(--line-strong); border-radius: 14px;
  padding: 9px 11px; font-size: 13px;
  box-shadow: 0 10px 26px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.05);
  transition: transform .18s ease, box-shadow .2s, border-color .2s;
}
.seat.to-act {
  border-color: var(--gold);
  box-shadow: 0 0 0 2px rgba(244,201,75,.35), 0 0 26px rgba(244,201,75,.5), 0 10px 26px rgba(0,0,0,.5);
  animation: pulseGold 1.6s ease-in-out infinite;
}
@keyframes pulseGold {
  0%, 100% { box-shadow: 0 0 0 2px rgba(244,201,75,.35), 0 0 20px rgba(244,201,75,.4), 0 10px 26px rgba(0,0,0,.5); }
  50% { box-shadow: 0 0 0 3px rgba(244,201,75,.55), 0 0 34px rgba(244,201,75,.7), 0 10px 26px rgba(0,0,0,.5); }
}
.seat.button::after {
  content: "D"; position: absolute; top: -12px; right: -8px;
  width: 24px; height: 24px; border-radius: 50%; font-size: 12px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  color: #3a2a00; background: linear-gradient(180deg, #fff, #d7c9a6);
  box-shadow: 0 3px 10px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.8);
  border: 1px solid rgba(0,0,0,.2);
}
.seat.folded { opacity: .4; filter: grayscale(.4); }
.seat.mine {
  width: 204px; z-index: 5;
  border-color: var(--gold);
  background: linear-gradient(180deg, rgba(30,26,14,.96), rgba(16,14,8,.96));
  box-shadow: 0 0 0 1px rgba(244,201,75,.35), 0 14px 34px rgba(0,0,0,.55);
}
.seat.mine .name { color: var(--gold-hi); }
.seat.threat {
  border-color: var(--red-hi);
  box-shadow: 0 0 0 2px rgba(239,77,84,.4), 0 0 26px rgba(239,77,84,.55), 0 10px 26px rgba(0,0,0,.5);
}
.seat .name { font-weight: 700; display: flex; justify-content: space-between; align-items: center; gap: 4px; }
.seat .chips { color: var(--gold-hi); margin-top: 3px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; font-weight: 700; }
.rebuy-tag { color: var(--teal); font-size: 10px; font-weight: 700; background: rgba(47,214,166,.12); padding: 1px 6px; border-radius: 6px; }
.seat .bet { color: var(--blue); font-size: 13px; min-height: 14px; font-weight: 600; }
/* 对手下注的筹码放大并高亮，便于看清 */
.seat:not(.mine) .bet {
  font-size: 17px; font-weight: 800; color: var(--red-hi); line-height: 1.2;
  background: rgba(239,77,84,.14); border: 1px solid rgba(239,77,84,.3);
  padding: 2px 8px; border-radius: 8px; display: inline-block; min-height: 0;
  text-shadow: 0 1px 3px rgba(0,0,0,.5);
}
.seat .cards { display: flex; gap: 5px; margin-top: 8px; justify-content: center; min-height: 44px; }
.seat .handname { color: #8fe6b0; font-size: 11px; min-height: 13px; font-weight: 600; }
.threat-badge {
  margin-top: 7px; font-size: 11px; font-weight: 800; text-align: center; letter-spacing: 1px;
  color: #fff; background: linear-gradient(180deg, var(--red-hi), #c9363c);
  border-radius: 7px; padding: 3px 0; box-shadow: 0 3px 10px rgba(239,77,84,.35);
}
.threat-badge.hidden { display: none; }

.tag { font-size: 10px; padding: 2px 7px; border-radius: 7px; background: rgba(255,255,255,.08); color: var(--muted); font-weight: 700; }
.tag.allin { background: linear-gradient(180deg, var(--red-hi), #c9363c); color: #fff; }
.tag.offline { background: #3a4150; color: #b9c2cf; }
.tag.bust { background: #5a1e1e; color: #ffb4b4; }
.tag.bot { background: linear-gradient(180deg, #7b5cff, #5a3fd6); color: #fff; }

/* ===================== 扑克牌 ===================== */
.card {
  position: relative; width: 42px; height: 60px; border-radius: 7px;
  background: linear-gradient(158deg, #ffffff 0%, #f1f3f7 100%); color: #16202e;
  box-shadow: 0 3px 8px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.9);
  font-weight: 800; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.card.deal { animation: dealIn .32s ease both; }
@keyframes dealIn { from { opacity: 0; transform: rotateY(-90deg) scale(.9); } to { opacity: 1; transform: none; } }
.card::before { /* 顶部光泽 */
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 42%;
  background: linear-gradient(180deg, rgba(255,255,255,.7), transparent); pointer-events: none;
}
.card .c-suit { font-size: 22px; line-height: 1; }
.card .c-idx {
  position: absolute; font-size: 11px; font-weight: 900; line-height: .92; letter-spacing: -.5px; text-align: center;
}
.card .c-idx.tl { top: 4px; left: 5px; }
.card .c-idx.br { bottom: 4px; right: 5px; transform: rotate(180deg); }
.card.red { color: #e02534; }
.card.back {
  background:
    repeating-linear-gradient(45deg, #1c3f8f 0, #1c3f8f 5px, #234fb0 5px, #234fb0 10px);
  color: transparent; box-shadow: 0 3px 8px rgba(0,0,0,.45), inset 0 0 0 2px rgba(255,255,255,.12);
}
.card.back::after {
  content: ""; position: absolute; inset: 4px; border-radius: 4px; border: 1px solid rgba(255,255,255,.28);
}
.card.small { width: 28px; height: 40px; border-radius: 5px; }
.card.small .c-suit { font-size: 14px; }
.card.small .c-idx { font-size: 8px; top: 2px; left: 3px; }
.card.small .c-idx.br { bottom: 2px; right: 3px; }
.card.big { width: 86px; height: 120px; border-radius: 13px; box-shadow: 0 9px 22px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.9); }
.card.big .c-suit { font-size: 48px; }
.card.big .c-idx { font-size: 21px; top: 8px; left: 9px; }
.card.big .c-idx.br { bottom: 8px; right: 9px; }
/* 对手威胁亮牌略小，避免座位溢出 */
.seat:not(.mine) .card.big { width: 72px; height: 100px; }
.seat:not(.mine) .card.big .c-suit { font-size: 40px; }

/* ===================== 动作栏 ===================== */
.action-bar {
  grid-area: action;
  background: linear-gradient(180deg, rgba(20,27,40,.9), rgba(13,18,28,.94));
  border-top: 1px solid var(--line); padding: 12px 18px; backdrop-filter: blur(8px);
}
.turn-info { font-size: 13px; color: var(--muted); margin-bottom: 9px; min-height: 17px; font-weight: 600; }
.turn-info b { color: var(--gold-hi); }
.controls { display: flex; gap: 8px; align-items: stretch; flex-wrap: wrap; }
.controls .act {
  width: auto; margin: 0; min-width: 72px; padding: 11px 17px;
  font-size: 14px; border-radius: 12px; font-weight: 800; letter-spacing: .5px;
}
#foldBtn.act { background: linear-gradient(180deg, #4a3336, #35262a); border-color: rgba(239,77,84,.35); color: #ffc9cc; }
#checkBtn.act, #callBtn.act { background: linear-gradient(180deg, #1f5a48, #164434); border-color: rgba(47,214,166,.4); color: #b8f5df; }
#betRaiseBtn.act { background: linear-gradient(180deg, var(--gold-hi), var(--gold-lo)); color: #3a2a00; border-color: rgba(255,224,138,.6); box-shadow: 0 5px 16px rgba(244,201,75,.25); }
#allinBtn.act { background: linear-gradient(180deg, var(--red-hi), #c9363c); color: #fff; border-color: rgba(255,107,112,.5); box-shadow: 0 5px 16px rgba(239,77,84,.28); }
.act:disabled { opacity: .36; cursor: not-allowed; transform: none; box-shadow: none; filter: none; }

/* 教练实时推荐：高亮对应动作按钮 */
.act.coach-pick {
  outline: 2px solid var(--gold-hi); outline-offset: 2px;
  box-shadow: 0 0 0 3px rgba(244,201,75,.35), 0 0 22px rgba(244,201,75,.55) !important;
  animation: coachPulse 1.1s ease-in-out infinite;
}
@keyframes coachPulse {
  0%,100% { box-shadow: 0 0 0 3px rgba(244,201,75,.3), 0 0 16px rgba(244,201,75,.4); }
  50% { box-shadow: 0 0 0 4px rgba(244,201,75,.55), 0 0 28px rgba(244,201,75,.7); }
}

/* 下注区：滑条 + 筹码档位 */
.betbox {
  flex: 1 1 300px; min-width: 260px;
  background: rgba(7,11,20,.55); border: 1px solid var(--line);
  border-radius: 14px; padding: 9px 11px; display: flex; flex-direction: column; gap: 8px;
}
.bet-head { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
.bet-cur { font-size: 14px; font-weight: 800; color: var(--gold-hi); }
.bet-hint { font-size: 11px; color: var(--muted); }
.bet-range { width: 100%; accent-color: var(--gold); cursor: pointer; height: 18px; }
.chips-row { display: flex; gap: 6px; flex-wrap: wrap; }
.chip {
  width: auto; margin: 0; flex: 1 1 auto; padding: 7px 5px; min-width: 48px;
  font-size: 11px; font-weight: 700; border-radius: 9px;
  background: linear-gradient(180deg, rgba(48,58,74,.9), rgba(33,41,54,.9));
  border: 1px solid var(--line-strong); color: var(--text);
}
.chip:hover { border-color: var(--gold); color: var(--gold-hi); }
.chip.max { background: linear-gradient(180deg, var(--red-hi), #c9363c); color: #fff; border-color: rgba(255,107,112,.4); }
.bet-actions { display: flex; gap: 8px; }
.bet-actions .act { flex: 1; }

.host-bar { margin-top: 13px; display: flex; gap: 9px; flex-wrap: wrap; }
.host-bar button { width: auto; margin: 0; padding: 11px 22px; }

/* 补码 */
.rebuy-bar { margin-top: 11px; display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
.rebuy-bar .ghost { width: auto; margin: 0; padding: 10px 15px; background: transparent; border: 1px solid rgba(47,214,166,.35); color: var(--teal); }
.rebuy-bar .ghost:hover { background: rgba(47,214,166,.1); }
.rebuy-row { display: flex; align-items: center; gap: 7px; background: rgba(7,11,20,.5); padding: 5px; border-radius: 12px; border: 1px solid var(--line); }
.rebuy-row input { width: 110px; margin: 0; padding: 9px 10px; }
.rebuy-row button { width: auto; margin: 0; padding: 9px 15px; }
.rebuy-row button.primary { background: linear-gradient(180deg, var(--gold-hi), var(--gold-lo)); color: #3a2a00; }

/* ===================== 侧栏 ===================== */
.sidebar {
  grid-area: side; display: flex; flex-direction: column; min-height: 0;
  background: linear-gradient(180deg, rgba(16,22,33,.6), rgba(10,14,22,.6));
  border-left: 1px solid var(--line); backdrop-filter: blur(10px);
}
.coach-panel, .reads-panel { padding: 15px; overflow-y: auto; border-bottom: 1px solid var(--line); }
.coach-panel { max-height: 50vh; }
.reads-panel { max-height: 44vh; }
.coach-head, .reads-head {
  display: flex; justify-content: space-between; align-items: center;
  font-weight: 800; font-size: 15px; margin-bottom: 12px;
  color: var(--gold-hi);
}
.coach-head .mini { width: auto; margin: 0; padding: 5px 11px; }
.coach-hint, .reads-hint { color: var(--muted); font-size: 13px; line-height: 1.65; }

/* 教练卡片 */
.coach-rec {
  font-size: 15px; margin-bottom: 12px; padding: 12px 14px; border-radius: 12px;
  background: linear-gradient(135deg, rgba(244,201,75,.14), rgba(244,201,75,.03));
  border: 1px solid rgba(244,201,75,.25);
}
.coach-rec .rec-label { color: var(--muted); margin-right: 8px; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
.coach-rec .rec-act { color: var(--gold-hi); font-size: 22px; font-weight: 900; }
.coach-rec .rec-amt { color: var(--text); font-size: 15px; margin-left: 6px; font-weight: 700; }
.coach-facts { font-size: 13px; color: #cdd7e3; margin-bottom: 8px; line-height: 1.7; }
.coach-facts b { color: #fff; }
.coach-odds {
  font-size: 13px; color: #8fe6b0; margin-bottom: 10px; font-weight: 600;
  background: rgba(47,214,166,.08); border: 1px solid rgba(47,214,166,.2);
  padding: 8px 11px; border-radius: 10px;
}
.coach-odds b { color: var(--teal); }
.coach-concept {
  font-size: 13px; color: #d6f2e2; line-height: 1.65; margin-bottom: 8px;
  background: rgba(7,11,20,.55); border-left: 3px solid var(--gold); padding: 9px 12px; border-radius: 0 10px 10px 0;
}
.coach-reason { font-size: 12px; color: var(--muted); line-height: 1.65; }

/* 起手牌强度进度条 */
.coach-strbar { margin: 2px 0 11px; }
.csb-label { font-size: 12px; color: var(--muted); margin-bottom: 6px; letter-spacing: .3px; }
.csb-label b { color: #fff; font-size: 15px; font-weight: 900; }
.csb-track { height: 9px; border-radius: 999px; background: rgba(255,255,255,.1); overflow: hidden; box-shadow: inset 0 1px 2px rgba(0,0,0,.4); }
.csb-fill { height: 100%; border-radius: 999px; transition: width .45s ease; box-shadow: 0 0 10px rgba(255,255,255,.15); }

/* 对手读牌 */
.read-card {
  background: linear-gradient(180deg, rgba(7,11,20,.6), rgba(7,11,20,.35));
  border: 1px solid var(--line); border-radius: 12px; padding: 11px 12px; margin-bottom: 11px;
  transition: border-color .15s, transform .15s;
}
.read-card:hover { border-color: var(--line-strong); transform: translateY(-1px); }
.read-top { display: flex; align-items: center; gap: 8px; }
.read-name { font-weight: 800; font-size: 14px; }
.read-badge { margin-left: auto; font-size: 11px; padding: 3px 10px; border-radius: 999px; font-weight: 800; letter-spacing: .5px; }
.read-badge.s-strong { background: linear-gradient(180deg, var(--red-hi), #c9363c); color: #fff; }
.read-badge.s-mid { background: linear-gradient(180deg, #4a9bff, #2a6cd0); color: #fff; }
.read-badge.s-weak { background: #3a4552; color: #cdd7e3; }
.read-badge.s-out { background: #2a3038; color: var(--muted); }
.read-badge.s-unk { background: #2a3038; color: var(--muted); }
.read-summary { font-size: 12px; color: #cdd7e3; margin: 7px 0; line-height: 1.55; }
.read-signals { font-size: 12px; color: #cdd7e3; margin: 4px 0; }
.read-sig { padding: 4px 0; border-bottom: 1px solid rgba(255,255,255,.05); line-height: 1.55; }
.read-sig:last-child { border-bottom: none; }
.sig-label { color: var(--gold-hi); font-weight: 800; margin-right: 4px; }
.read-strength {
  font-size: 12px; color: #8fe6b0; margin: 8px 0; line-height: 1.55;
  background: rgba(47,214,166,.08); border-left: 3px solid #2f8f5b; padding: 7px 10px; border-radius: 0 9px 9px 0;
}
.read-teach { margin-top: 7px; }
.teach-item { font-size: 12px; color: #d6f2e2; line-height: 1.6; margin: 4px 0; }

/* 日志 */
.log-panel { flex: 1; min-height: 0; padding: 15px; overflow-y: auto; }
.log-panel h3 { margin: 0 0 12px; font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
.log-panel ul { list-style: none; margin: 0; padding: 0; font-size: 13px; }
.log-panel li { padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.05); color: #b9c4d1; line-height: 1.5; }

/* ===================== 响应式 ===================== */
@media (max-width: 860px) {
  #game { grid-template-columns: 1fr; grid-template-areas: "top" "table" "action" "side"; height: auto; }
  .sidebar { border-left: none; border-top: 1px solid var(--line); }
  .coach-panel, .reads-panel { max-height: none; }
  .log-panel { max-height: 220px; }
  .table { width: 100%; }
}

/* ===== 战绩 / 管理后台 ===== */
.lobby-card.wide { max-width: 780px; }
.stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 14px 0; }
.stat-card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px; text-align: center; }
.sc-k { font-size: 12px; opacity: .7; }
.sc-v { font-size: 20px; font-weight: 800; color: var(--gold); margin-top: 4px; }
.cat-line { font-size: 13px; opacity: .85; margin: 6px 0 12px; }
.sugg { margin-top: 8px; }
.sugg h4 { margin: 6px 0; }
.sugg-item { border-left: 3px solid var(--gold); padding: 8px 10px; margin: 6px 0; background: rgba(255,255,255,.05); border-radius: 6px; font-size: 14px; line-height: 1.5; }
.sugg-item.warn { border-left-color: #ffb454; }
.sugg-item.good { border-left-color: #4ade80; }
.sugg-item.info { border-left-color: #60a5fa; }
.admin-sec { margin: 16px 0; padding-top: 12px; border-top: 1px dashed rgba(255,255,255,.12); }
.admin-sec h3 { margin: 0 0 8px; font-size: 15px; }
.invite-code { font-size: 28px; font-weight: 900; letter-spacing: 4px; color: var(--gold); margin: 10px 0; padding: 10px; background: rgba(0,0,0,.25); border-radius: 8px; text-align: center; }
.acct-table { width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 14px; }
.acct-table th, .acct-table td { padding: 8px 6px; text-align: left; border-bottom: 1px solid rgba(255,255,255,.08); }
.acct-table th { opacity: .7; font-weight: 600; }
.stats-body, .acct-body { margin-top: 6px; }
